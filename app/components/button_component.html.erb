<% if link? %>
  <%= tag.a(**tag_options) do %>
    <% if icon %><%= helpers.heroicon icon, class: icon_classes %><% end %>
    <%= content %>
  <% end %>
<% else %>
  <%= tag.button(**tag_options) do %>
    <% if icon %><%= helpers.heroicon icon, class: icon_classes %><% end %>
    <%= content %>
  <% end %>
<% end %>
