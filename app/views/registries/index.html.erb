<div class="max-w-6xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-4xl font-bold text-blue-900 dark:text-white mb-2">Registry Management</h1>
      <p class="text-blue-700 dark:text-gray-400">Manage your Docker Registry connections</p>
    </div>
    <%= link_to "Add Registry", new_registry_path, class: "inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors" %>
  </div>

  <% if @env_registry %>
    <div class="mb-6 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-blue-600 dark:text-blue-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div class="flex-1">
          <h3 class="text-sm font-semibold text-blue-900 dark:text-blue-200"><%= @env_registry[:name] %></h3>
          <p class="text-sm text-blue-700 dark:text-blue-300 mt-1"><%= @env_registry[:url] %></p>
          <p class="text-xs text-blue-600 dark:text-blue-400 mt-1">Configured via environment variables (read-only)</p>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-blue-50 dark:bg-gray-800 rounded-lg shadow border border-blue-200 dark:border-gray-700 overflow-hidden">
    <% if @registries.any? %>
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-blue-100 dark:bg-gray-900">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-blue-600 dark:text-gray-400 uppercase tracking-wider">
              Status
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-blue-600 dark:text-gray-400 uppercase tracking-wider">
              Name
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-blue-600 dark:text-gray-400 uppercase tracking-wider">
              URL
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-blue-600 dark:text-gray-400 uppercase tracking-wider">
              Last Connected
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-blue-600 dark:text-gray-400 uppercase tracking-wider">
              Actions
            </th>
          </tr>
        </thead>
        <tbody class="bg-blue-50 dark:bg-gray-800 divide-y divide-blue-200 dark:divide-gray-700">
          <% @registries.each do |registry| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center gap-2">
                  <span class="text-lg <%= registry.connection_status == :connected ? 'text-green-600' : registry.connection_status == :stale ? 'text-yellow-600' : 'text-gray-400' %>">
                    <%= registry.connection_status_icon %>
                  </span>
                  <% if registry.is_default %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200">
                      Default
                    </span>
                  <% end %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-blue-900 dark:text-white">
                  <%= registry.name %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-blue-700 dark:text-gray-300">
                  <%= registry.url %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-blue-600 dark:text-gray-400">
                <%= registry.last_connected_at ? time_ago_in_words(registry.last_connected_at) + " ago" : "Never" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <div class="flex items-center justify-end gap-2">
                  <%= link_to "Edit", edit_registry_path(registry), class: "text-blue-600 hover:text-blue-900 dark:text-blue-400 dark:hover:text-blue-300" %>
                  <%= button_to "Delete", registry_path(registry), method: :delete, 
                    form: { data: { turbo_confirm: "Are you sure you want to delete this registry?" } },
                    class: "text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/>
        </svg>
        <h3 class="mt-2 text-lg font-medium text-blue-900 dark:text-white">No registries configured</h3>
        <p class="mt-1 text-blue-600 dark:text-gray-400">Get started by adding your first Docker Registry</p>
        <div class="mt-6">
          <%= link_to "Add Registry", new_registry_path, class: "inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-6">
    <%= link_to root_path, class: "inline-flex items-center text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Repositories
    <% end %>
  </div>
</div>
