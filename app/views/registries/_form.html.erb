<%= form_with(model: registry, data: { controller: "registry-form" }, class: "space-y-6") do |form| %>
  <% if registry.errors.any? %>
    <div class="rounded-lg bg-red-50 dark:bg-red-900/20 p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
            <%= pluralize(registry.errors.count, "error") %> prohibited this registry from being saved:
          </h3>
          <ul class="mt-2 text-sm text-red-700 dark:text-red-300 list-disc list-inside">
            <% registry.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-blue-800 dark:text-gray-300 mb-2" %>
    <%= form.text_field :name,
      required: true,
      placeholder: "Production Registry",
      class: "block w-full rounded-md border-blue-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 bg-white dark:bg-gray-700 text-blue-900 dark:text-white" %>
  </div>

  <div>
    <%= form.label :url, class: "block text-sm font-medium text-blue-800 dark:text-gray-300 mb-2" %>
    <%= form.text_field :url,
      required: true,
      placeholder: "https://registry.example.com",
      data: { registry_form_target: "url" },
      class: "block w-full rounded-md border-blue-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 bg-white dark:bg-gray-700 text-blue-900 dark:text-white" %>
    <p class="mt-1 text-xs text-blue-600 dark:text-gray-400">Docker Registry V2 API URL</p>
  </div>

  <div>
    <%= form.label :username, "Username (optional)", class: "block text-sm font-medium text-blue-800 dark:text-gray-300 mb-2" %>
    <%= form.text_field :username,
      placeholder: "username",
      data: { registry_form_target: "username" },
      class: "block w-full rounded-md border-blue-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 bg-white dark:bg-gray-700 text-blue-900 dark:text-white" %>
  </div>

  <div>
    <%= form.label :password, "Password (optional)", class: "block text-sm font-medium text-blue-800 dark:text-gray-300 mb-2" %>
    <%= form.password_field :password,
      placeholder: "••••••••",
      data: { registry_form_target: "password" },
      class: "block w-full rounded-md border-blue-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 bg-white dark:bg-gray-700 text-blue-900 dark:text-white" %>
    <% if registry.persisted? && registry.password_digest.present? %>
      <p class="mt-1 text-xs text-blue-600 dark:text-gray-400">Leave blank to keep current password</p>
    <% end %>
  </div>

  <div class="flex items-center gap-6">
    <div class="flex items-center">
      <%= form.check_box :is_default, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-blue-300 rounded" %>
      <%= form.label :is_default, "Set as default registry", class: "ml-2 text-sm text-blue-800 dark:text-gray-300" %>
    </div>

    <div class="flex items-center">
      <%= form.check_box :is_active, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-blue-300 rounded" %>
      <%= form.label :is_active, "Active", class: "ml-2 text-sm text-blue-800 dark:text-gray-300" %>
    </div>
  </div>

  <div 
    data-registry-form-target="testResult"
    class="hidden rounded-lg p-4 flex items-center gap-3"
  >
    <div data-registry-form-target="testIcon"></div>
    <div data-registry-form-target="testMessage" class="text-sm font-medium"></div>
  </div>

  <div class="flex items-center gap-4 pt-6 border-t border-blue-200 dark:border-gray-700">
    <button
      type="button"
      data-action="click->registry-form#testConnection"
      data-registry-form-target="testButton"
      class="inline-flex items-center px-4 py-2 border border-blue-300 dark:border-gray-600 shadow-sm text-sm font-medium rounded-md text-blue-800 dark:text-gray-300 bg-blue-50 dark:bg-gray-800 hover:bg-blue-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
    >
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      Test Connection
    </button>

    <%= form.submit "Save Registry",
      class: "inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors" %>

    <%= link_to "Cancel", registries_path,
      class: "inline-flex items-center px-4 py-2 text-blue-800 dark:text-gray-300 hover:text-blue-900 dark:hover:text-white" %>
  </div>
<% end %>
