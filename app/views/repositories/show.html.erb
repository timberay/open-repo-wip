<%# Back navigation %>
<div class="mb-6">
  <%= link_to repositories_path, class: "inline-flex items-center gap-2 text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors duration-150" do %>
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/>
    </svg>
    Back to Repositories
  <% end %>
</div>

<%# Repository info card %>
<div class="rounded-lg bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-sm p-6 mb-6">
  <div class="flex items-start justify-between gap-4 mb-4">
    <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100 break-keep"><%= @repository.name %></h1>
    <div class="flex items-center gap-3 flex-shrink-0">
      <span class="inline-flex items-center px-2.5 py-1 rounded-full text-sm font-medium bg-green-200 text-green-800 dark:bg-green-900/30 dark:text-green-400 ring-1 ring-inset ring-green-600/20 dark:ring-green-400/20">
        <%= @tags.count %> tags
      </span>
      <span class="text-sm text-slate-600 dark:text-slate-400"><%= human_size(@repository.total_size) %></span>
    </div>
  </div>

  <% if @repository.description.present? || @repository.maintainer.present? %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-4">
      <% if @repository.description.present? %>
        <div class="flex items-start gap-3 rounded-md bg-slate-100 dark:bg-slate-700/50 px-4 py-3">
          <svg class="w-5 h-5 text-slate-400 dark:text-slate-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
          </svg>
          <div>
            <p class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-0.5">Description</p>
            <p class="text-base text-slate-900 dark:text-slate-100"><%= @repository.description %></p>
          </div>
        </div>
      <% end %>
      <% if @repository.maintainer.present? %>
        <div class="flex items-start gap-3 rounded-md bg-slate-100 dark:bg-slate-700/50 px-4 py-3">
          <svg class="w-5 h-5 text-slate-400 dark:text-slate-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
          </svg>
          <div>
            <p class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-0.5">Maintainer</p>
            <p class="text-base text-slate-900 dark:text-slate-100"><%= @repository.maintainer %></p>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Edit form (collapsible) %>
  <div class="pt-4 border-t border-slate-200 dark:border-slate-700">
    <details class="group">
      <summary class="cursor-pointer text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors duration-150 select-none">
        <svg class="w-4 h-4 inline-block mr-1 transition-transform duration-150 group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
        </svg>
        Edit description & maintainer
      </summary>
      <div class="mt-4">
        <%= form_with model: @repository, url: repository_path(@repository.name), method: :patch, class: "space-y-4" do |f| %>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Description</label>
            <%= f.text_area :description, rows: 4, placeholder: "Describe the purpose of this repository, included tools, etc.",
              class: "block w-full rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 py-2.5 text-base text-slate-900 dark:text-slate-100 placeholder:text-slate-400 dark:placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20 dark:focus:ring-blue-400/20 focus:border-blue-500 dark:focus:border-blue-400 transition-colors duration-150 resize-y" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Maintainer</label>
            <%= f.text_field :maintainer, placeholder: "Name or team...",
              class: "block w-full h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-base text-slate-900 dark:text-slate-100 placeholder:text-slate-400 dark:placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20 dark:focus:ring-blue-400/20 focus:border-blue-500 dark:focus:border-blue-400 transition-colors duration-150" %>
          </div>
          <div class="flex items-center gap-3">
            <%= f.submit "Save", class: "inline-flex items-center gap-2 h-10 px-4 text-base font-medium text-white bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-400 rounded-md transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900 cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </details>
  </div>

  <%# Docker pull command %>
  <% if @tags.any? %>
    <div class="mt-4 bg-slate-100 dark:bg-slate-900 rounded-md px-4 py-3 flex items-center justify-between gap-3"
         data-controller="clipboard"
         data-clipboard-text-value="<%= docker_pull_command(@repository.name, @tags.first.name) %>">
      <code class="text-sm font-mono text-slate-800 dark:text-blue-300 break-all"><%= docker_pull_command(@repository.name, @tags.first.name) %></code>
      <button data-action="click->clipboard#copy" class="flex-shrink-0 p-2 rounded-md text-slate-400 hover:text-slate-600 dark:text-slate-500 dark:hover:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors duration-150" aria-label="Copy command">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184"/>
        </svg>
      </button>
    </div>
  <% end %>
</div>

<%# Tags list — desktop CSS Grid %>
<% if @tags.any? %>
  <div class="hidden md:block rounded-lg border border-slate-200 dark:border-slate-700 overflow-hidden">
    <%# Header %>
    <div class="grid bg-slate-100 dark:bg-slate-800/80"
         style="grid-template-columns: minmax(120px, 1fr) 140px 100px 120px 80px minmax(100px, 1fr) 100px">
      <div class="px-4 py-3 text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Tag</div>
      <div class="px-4 py-3 text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Digest</div>
      <div class="px-4 py-3 text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Size</div>
      <div class="px-4 py-3 text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Arch</div>
      <div class="px-4 py-3 text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Pulls</div>
      <div class="px-4 py-3 text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Updated</div>
      <div class="px-4 py-3 text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">Actions</div>
    </div>
    <%# Body rows %>
    <% @tags.each do |tag| %>
      <div class="grid border-t border-slate-100 dark:border-slate-700/50 hover:bg-slate-50/50 dark:hover:bg-slate-700/50 transition-colors"
           style="grid-template-columns: minmax(120px, 1fr) 140px 100px 120px 80px minmax(100px, 1fr) 100px">
        <div class="px-4 py-3">
          <%= link_to tag.name, repository_tag_path(@repository.name, tag),
            class: "text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 hover:underline" %>
        </div>
        <div class="px-4 py-3 text-sm text-slate-600 dark:text-slate-400 font-mono tabular-nums">
          <%= short_digest(tag.manifest.digest) %>
        </div>
        <div class="px-4 py-3 text-sm text-slate-600 dark:text-slate-400 tabular-nums">
          <%= human_size(tag.manifest.size) %>
        </div>
        <div class="px-4 py-3 text-sm text-slate-600 dark:text-slate-400">
          <%= tag.manifest.architecture %>/<%= tag.manifest.os %>
        </div>
        <div class="px-4 py-3 text-sm text-slate-600 dark:text-slate-400 tabular-nums">
          <%= tag.manifest.pull_count %>
        </div>
        <div class="px-4 py-3 text-sm text-slate-400 dark:text-slate-500">
          <%= time_ago_in_words(tag.updated_at) %> ago
        </div>
        <div class="px-4 py-3 flex items-center justify-end">
          <%= button_to repository_tag_path(@repository.name, tag), method: :delete,
            data: { turbo_confirm: "Delete tag '#{tag.name}'? This action cannot be undone." },
            class: "inline-flex items-center gap-1.5 text-sm font-medium text-red-600 dark:text-red-400 hover:text-red-700 dark:hover:text-red-300 transition-colors duration-150" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/>
            </svg>
            Delete
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# Tags list — mobile card stack %>
  <div class="md:hidden space-y-3">
    <% @tags.each do |tag| %>
      <div class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-4 shadow-sm">
        <div class="flex items-start justify-between gap-3 mb-2">
          <%= link_to tag.name, repository_tag_path(@repository.name, tag),
            class: "text-base font-medium text-blue-600 dark:text-blue-400 hover:underline" %>
          <span class="text-sm text-slate-400 dark:text-slate-500 flex-shrink-0"><%= time_ago_in_words(tag.updated_at) %> ago</span>
        </div>
        <div class="space-y-1 mb-3">
          <p class="text-sm text-slate-600 dark:text-slate-400 font-mono tabular-nums">Digest: <%= short_digest(tag.manifest.digest) %></p>
          <p class="text-sm text-slate-600 dark:text-slate-400">Size: <%= human_size(tag.manifest.size) %> &middot; <%= tag.manifest.architecture %>/<%= tag.manifest.os %> &middot; Pulls: <%= tag.manifest.pull_count %></p>
        </div>
        <div class="flex items-center gap-2">
          <%= button_to repository_tag_path(@repository.name, tag), method: :delete,
            data: { turbo_confirm: "Delete tag '#{tag.name}'?" },
            class: "inline-flex items-center gap-1.5 h-8 px-3 text-sm font-medium text-red-600 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/30 rounded-md transition-colors duration-150" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/>
            </svg>
            Delete
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <%# Empty state %>
  <div class="flex flex-col items-center justify-center py-16 px-4">
    <svg class="w-12 h-12 text-slate-300 dark:text-slate-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z"/>
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z"/>
    </svg>
    <h3 class="text-lg font-semibold text-slate-700 dark:text-slate-300 mb-1">No tags found</h3>
    <p class="text-sm text-slate-500 dark:text-slate-400 text-center max-w-sm">Push an image to create tags.</p>
  </div>
<% end %>

<%# Delete repository %>
<div class="mt-6 flex items-center justify-end">
  <%= button_to repository_path(@repository.name), method: :delete,
    data: { turbo_confirm: "Delete repository '#{@repository.name}' and all its tags? This action cannot be undone." },
    class: "inline-flex items-center gap-2 h-10 px-4 text-base font-medium text-white bg-red-600 hover:bg-red-700 dark:bg-red-500 dark:hover:bg-red-400 rounded-md transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-red-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-red-400/50 dark:focus-visible:ring-offset-slate-900" do %>
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/>
    </svg>
    Delete Repository
  <% end %>
</div>
