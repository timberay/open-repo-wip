<%# Back navigation %>
<div class="mb-6">
  <%= link_to repositories_path, class: "inline-flex items-center gap-2 text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors duration-150" do %>
    <%= heroicon "chevron-left", class: "w-5 h-5" %>
    Back to Repositories
  <% end %>
</div>

<%# Repository info card %>
<%= render CardComponent.new(padding: :none, class: "mb-6") do %>
  <div class="p-6">
    <div class="flex items-start justify-between gap-4 mb-4">
      <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100 break-keep"><%= @repository.name %></h1>
      <div class="flex items-center gap-3 flex-shrink-0">
        <%= render(BadgeComponent.new(variant: :default)) { "#{@tags.count} tags" } %>
        <span class="text-sm text-slate-600 dark:text-slate-400"><%= human_size(@repository.total_size) %></span>
      </div>
    </div>

    <% if @repository.description.present? || @repository.maintainer.present? %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-4">
        <% if @repository.description.present? %>
          <div class="flex items-start gap-3 rounded-md bg-slate-100 dark:bg-slate-700/50 px-4 py-3">
            <%= heroicon "document-text", class: "w-5 h-5 text-slate-400 dark:text-slate-500 flex-shrink-0 mt-0.5" %>
            <div>
              <p class="text-sm font-medium text-slate-700 dark:text-slate-300 mb-0.5">Description</p>
              <p class="text-base text-slate-900 dark:text-slate-100"><%= @repository.description %></p>
            </div>
          </div>
        <% end %>
        <% if @repository.maintainer.present? %>
          <div class="flex items-start gap-3 rounded-md bg-slate-100 dark:bg-slate-700/50 px-4 py-3">
            <%= heroicon "user", class: "w-5 h-5 text-slate-400 dark:text-slate-500 flex-shrink-0 mt-0.5" %>
            <div>
              <p class="text-sm font-medium text-slate-700 dark:text-slate-300 mb-0.5">Maintainer</p>
              <p class="text-base text-slate-900 dark:text-slate-100"><%= @repository.maintainer %></p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Edit form (collapsible) %>
    <div class="pt-4 border-t border-slate-200 dark:border-slate-700">
      <details class="group">
        <summary class="list-none [&::-webkit-details-marker]:hidden cursor-pointer text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors duration-150 select-none focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900 rounded-md outline-none">
          <%= heroicon "chevron-right", class: "w-4 h-4 inline-block mr-1 transition-transform duration-150 group-open:rotate-90" %>
          Edit description & maintainer
        </summary>
        <div class="mt-4">
          <%= form_with model: @repository, url: repository_path(@repository.name), method: :patch, class: "space-y-4",
                        data: { controller: "tag-protection" } do |f| %>
            <%= render TextareaComponent.new(
                  name: "repository[description]",
                  id: "repository_description",
                  value: @repository.description,
                  label: "Description",
                  rows: 4,
                  placeholder: "Describe the purpose of this repository, included tools, etc."
                ) %>
            <%= render InputComponent.new(
                  name: "repository[maintainer]",
                  id: "repository_maintainer",
                  value: @repository.maintainer,
                  label: "Maintainer",
                  placeholder: "Name or team..."
                ) %>
            <%= render SelectComponent.new(
                  name: "repository[tag_protection_policy]",
                  id: "repository_tag_protection_policy",
                  label: "Tag protection policy",
                  options: [
                    ["No protection",                      "none"],
                    ["Protect semver tags (v1.2.3)",       "semver"],
                    ["Protect everything except 'latest'", "all_except_latest"],
                    ["Match by custom regex",              "custom_regex"]
                  ],
                  selected: @repository.tag_protection_policy,
                  data: { tag_protection_target: "policy", action: "change->tag-protection#toggle" }
                ) %>
            <div data-tag-protection-target="regexWrapper" <%= 'hidden' unless @repository.protection_custom_regex? %>>
              <%= render InputComponent.new(
                    name: "repository[tag_protection_pattern]",
                    id: "repository_tag_protection_pattern",
                    value: @repository.tag_protection_pattern,
                    label: "Protection pattern (regex)",
                    placeholder: '^release-\d+$',
                    help_text: "Ruby regex. Tag names matching this pattern will be protected from overwrite and delete.",
                    class: "font-mono"
                  ) %>
            </div>
            <div class="flex items-center gap-3">
              <%= render(ButtonComponent.new(variant: :primary, type: :submit, icon: "check")) { "Save" } %>
            </div>
          <% end %>
        </div>
      </details>
    </div>

    <%# Docker pull command %>
    <% if @tags.any? %>
      <div class="mt-4 bg-slate-100 dark:bg-slate-900 rounded-md px-4 py-3 flex items-center justify-between gap-3"
           data-controller="clipboard"
           data-clipboard-text-value="<%= docker_pull_command(@repository.name, @tags.first.name) %>">
        <code class="flex-1 min-w-0 overflow-x-auto whitespace-nowrap text-sm font-mono text-slate-800 dark:text-blue-300"><%= docker_pull_command(@repository.name, @tags.first.name) %></code>
        <button data-action="click->clipboard#copy" class="flex-shrink-0 p-2 rounded-md text-slate-400 hover:text-slate-600 dark:text-slate-500 dark:hover:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors duration-150" aria-label="Copy command">
          <%= heroicon "clipboard", class: "w-5 h-5" %>
        </button>
      </div>
    <% end %>
  </div>
<% end %>

<%# Tags list — desktop CSS Grid %>
<% if @tags.any? %>
  <div class="hidden md:block rounded-lg border border-slate-200 dark:border-slate-700 overflow-hidden">
    <%# Header %>
    <div class="grid bg-slate-100 dark:bg-slate-800/80"
         style="grid-template-columns: minmax(120px, 1fr) 140px 100px 120px 80px minmax(100px, 1fr) 100px">
      <div class="px-4 py-3 text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Tag</div>
      <div class="px-4 py-3 text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Digest</div>
      <div class="px-4 py-3 text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Size</div>
      <div class="px-4 py-3 text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Arch</div>
      <div class="px-4 py-3 text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Pulls</div>
      <div class="px-4 py-3 text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Updated</div>
      <div class="px-4 py-3 text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">Actions</div>
    </div>
    <%# Body rows %>
    <% @tags.each do |tag| %>
      <div class="grid border-t border-slate-100 dark:border-slate-700/50 hover:bg-slate-50/50 dark:hover:bg-slate-700/50 transition-colors"
           style="grid-template-columns: minmax(120px, 1fr) 140px 100px 120px 80px minmax(100px, 1fr) 100px">
        <div class="px-4 py-3">
          <div class="flex items-center gap-2">
            <%= link_to tag.name, repository_tag_path(@repository.name, tag),
              class: "text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 hover:underline" %>
            <% if @repository.tag_protected?(tag.name) %>
              <%= render(BadgeComponent.new(
                    variant: :warning,
                    icon: "lock-closed",
                    role: "img",
                    "aria-label": "Protected tag (policy: #{@repository.tag_protection_policy})"
                  )) { "Protected" } %>
            <% end %>
          </div>
        </div>
        <div class="px-4 py-3 text-sm text-slate-600 dark:text-slate-400 font-mono tabular-nums">
          <%= short_digest(tag.manifest.digest) %>
        </div>
        <div class="px-4 py-3 text-sm text-slate-600 dark:text-slate-400 tabular-nums">
          <%= human_size(tag.manifest.size) %>
        </div>
        <div class="px-4 py-3 text-sm text-slate-600 dark:text-slate-400">
          <%= tag.manifest.architecture %>/<%= tag.manifest.os %>
        </div>
        <div class="px-4 py-3 text-sm text-slate-600 dark:text-slate-400 tabular-nums">
          <%= tag.manifest.pull_count %>
        </div>
        <div class="px-4 py-3 text-sm text-slate-400 dark:text-slate-500">
          <%= time_ago_in_words(tag.updated_at) %> ago
        </div>
        <div class="px-4 py-3 flex items-center justify-end">
          <% if @repository.tag_protected?(tag.name) %>
            <span class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-400 dark:text-slate-500 cursor-not-allowed"
                  title="Change the repository's tag protection policy to delete this tag.">
              <%= heroicon "trash", class: "w-4 h-4" %>
              Delete
            </span>
          <% else %>
            <%= button_to repository_tag_path(@repository.name, tag), method: :delete,
              data: { turbo_confirm: "Delete tag '#{tag.name}'? This action cannot be undone." },
              class: "inline-flex items-center justify-center font-medium rounded-md transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900 text-blue-600 hover:text-blue-700 underline-offset-4 hover:underline dark:text-blue-400 dark:hover:text-blue-300 h-8 px-3 text-sm gap-2" do %>
              <%= heroicon "trash", class: "w-4 h-4" %>
              Delete
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# Tags list — mobile card stack %>
  <div class="md:hidden space-y-3">
    <% @tags.each do |tag| %>
      <div class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-4 shadow-sm">
        <div class="flex items-start justify-between gap-3 mb-2">
          <div class="flex items-center gap-2 min-w-0">
            <%= link_to tag.name, repository_tag_path(@repository.name, tag),
              class: "text-base font-medium text-blue-600 dark:text-blue-400 hover:underline truncate" %>
            <% if @repository.tag_protected?(tag.name) %>
              <%= render(BadgeComponent.new(
                    variant: :warning,
                    icon: "lock-closed",
                    role: "img",
                    "aria-label": "Protected tag (policy: #{@repository.tag_protection_policy})",
                    class: "flex-shrink-0"
                  )) { "Protected" } %>
            <% end %>
          </div>
          <span class="text-sm text-slate-400 dark:text-slate-500 flex-shrink-0"><%= time_ago_in_words(tag.updated_at) %> ago</span>
        </div>
        <div class="space-y-1 mb-3">
          <p class="text-sm text-slate-600 dark:text-slate-400 font-mono tabular-nums">Digest: <%= short_digest(tag.manifest.digest) %></p>
          <p class="text-sm text-slate-600 dark:text-slate-400">Size: <%= human_size(tag.manifest.size) %> &middot; <%= tag.manifest.architecture %>/<%= tag.manifest.os %> &middot; Pulls: <%= tag.manifest.pull_count %></p>
        </div>
        <div class="flex items-center gap-2">
          <% if @repository.tag_protected?(tag.name) %>
            <span class="inline-flex items-center gap-1.5 h-8 px-3 text-sm font-medium text-slate-400 dark:text-slate-500 cursor-not-allowed"
                  title="Change the repository's tag protection policy to delete this tag.">
              Delete
            </span>
          <% else %>
            <%= button_to repository_tag_path(@repository.name, tag), method: :delete,
              data: { turbo_confirm: "Delete tag '#{tag.name}'?" },
              class: "inline-flex items-center justify-center font-medium rounded-md transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900 text-blue-600 hover:text-blue-700 underline-offset-4 hover:underline dark:text-blue-400 dark:hover:text-blue-300 h-8 px-3 text-sm gap-2" do %>
              <%= heroicon "trash", class: "w-4 h-4" %>
              Delete
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <%# Empty state %>
  <div class="flex flex-col items-center justify-center py-16 px-4">
    <%= heroicon "tag", class: "w-12 h-12 text-slate-300 dark:text-slate-600 mb-4" %>
    <h3 class="text-lg font-semibold text-slate-700 dark:text-slate-300 mb-1">No tags found</h3>
    <p class="text-sm text-slate-500 dark:text-slate-400 text-center max-w-sm">Push an image to create tags.</p>
  </div>
<% end %>

<%# Danger Zone %>
<section aria-labelledby="danger-zone" class="mt-8 pt-6 border-t border-slate-200 dark:border-slate-700">
  <h2 id="danger-zone" class="text-sm font-semibold text-red-700 dark:text-red-400 mb-2">Danger Zone</h2>
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <p class="text-sm text-slate-600 dark:text-slate-400">
      Deleting this repository removes all tags, manifests, and blob references. This cannot be undone.
    </p>
    <%= button_to repository_path(@repository.name), method: :delete,
      data: { turbo_confirm: "Delete repository '#{@repository.name}' and all its tags? This action cannot be undone." },
      class: "inline-flex items-center justify-center font-medium rounded-md transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900 bg-red-600 hover:bg-red-700 text-white dark:bg-red-500 dark:hover:bg-red-400 h-10 px-4 text-base gap-2 shrink-0" do %>
      <%= heroicon "trash", class: "w-5 h-5" %>
      Delete Repository
    <% end %>
  </div>
</section>
