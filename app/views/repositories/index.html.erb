<div class="max-w-7xl mx-auto">
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-2">Docker Registry</h1>
    <p class="text-gray-600 dark:text-gray-400">Browse and search Docker images from your registry</p>
  </div>

  <div class="mb-6 bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-4">
    <%= form_with url: repositories_path, method: :get, 
        data: { controller: "search", search_target: "form", turbo_frame: "repositories" },
        class: "flex flex-col sm:flex-row gap-4" do |f| %>
      
      <div class="flex-1">
        <%= f.text_field :query, 
          value: @query,
          placeholder: "Search repositories...",
          data: { action: "input->search#search" },
          class: "block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-gray-700 dark:text-white" %>
      </div>

      <div class="sm:w-48">
        <%= f.select :sort_by, 
          options_for_select([
            ["Name (A-Z)", "name"],
            ["Name (Z-A)", "name_desc"]
          ], @sort_by),
          {},
          { 
            data: { action: "change->search#search" },
            class: "block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-gray-700 dark:text-white"
          } %>
      </div>
    <% end %>
  </div>

  <%= turbo_frame_tag "repositories" do %>
    <% if @repositories.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-6">
        <% @repositories.each do |repository| %>
          <%= render "repository_card", repository: repository %>
        <% end %>
      </div>

      <% if @next_page %>
        <div class="text-center">
          <%= link_to "Load More", 
            repositories_path(query: @query, sort_by: @sort_by, page: @next_page),
            class: "inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 shadow-sm text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700" %>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
        </svg>
        <h3 class="mt-2 text-lg font-medium text-gray-900 dark:text-white">No repositories found</h3>
        <p class="mt-1 text-gray-500 dark:text-gray-400">
          <% if @query.present? %>
            Try adjusting your search query
          <% else %>
            No repositories available in the registry
          <% end %>
        </p>
      </div>
    <% end %>
  <% end %>
</div>
