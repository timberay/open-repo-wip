<%# Search & Sort bar %>
<%= render CardComponent.new(padding: :none, class: "mb-6") do %>
  <div class="p-4">
    <%= form_with url: repositories_path, method: :get,
        data: { controller: "search", search_target: "form", turbo_frame: "repositories" },
        class: "flex flex-col sm:flex-row items-center gap-3" do |f| %>

      <div class="flex-1 w-full">
        <%= render InputComponent.new(
              name: "q",
              value: params[:q],
              type: :search,
              size: :md,
              placeholder: "Search by name, description, or maintainer...",
              data: { action: "input->search#search" }
            ) %>
      </div>

      <div class="w-full sm:w-48">
        <%= render SelectComponent.new(
              name: "sort",
              options: [
                ["Recent", ""],
                ["Name (A-Z)", "name"],
                ["Size", "size"],
                ["Pulls", "pulls"]
              ],
              selected: params[:sort],
              size: :md,
              data: { action: "change->search#search" }
            ) %>
      </div>
    <% end %>
  </div>
<% end %>

<%# Repository list %>
<%= turbo_frame_tag "repositories" do %>
  <% if @repositories.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 lg:gap-6">
      <% @repositories.each do |repository| %>
        <%= render "repository_card", repository: repository %>
      <% end %>
    </div>
  <% else %>
    <div class="flex flex-col items-center justify-center py-16 px-4">
      <%= heroicon "archive-box", class: "w-12 h-12 text-slate-300 dark:text-slate-600 mb-4" %>
      <h3 class="text-lg font-semibold text-slate-700 dark:text-slate-300 mb-1">
        <% if params[:q].present? %>
          No results found
        <% else %>
          No repositories yet
        <% end %>
      </h3>
      <p class="text-sm text-slate-500 dark:text-slate-400 text-center max-w-sm break-keep">
        <% if params[:q].present? %>
          Try adjusting your search query.
        <% else %>
          Push an image to get started.
        <% end %>
      </p>
    </div>
  <% end %>
<% end %>
