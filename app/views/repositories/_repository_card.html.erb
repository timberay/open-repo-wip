<%= link_to repository_path(repository.name),
            data: { turbo_frame: "_top" },
            class: "block" do %>
  <%= render CardComponent.new(
               padding: :none,
               class: "hover:shadow-md transition-shadow duration-150"
             ) do %>
    <div class="p-6">
      <div class="flex items-start justify-between">
        <div class="flex-1 min-w-0">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100 truncate">
            <%= repository.name %>
          </h3>
          <% if repository.description.present? %>
            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400 line-clamp-2 break-keep"><%= repository.description %></p>
          <% end %>

          <div class="mt-2 flex items-center gap-4 text-sm text-slate-600 dark:text-slate-400">
            <div class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z"/>
              </svg>
              <span><%= repository.tags_count %> tags</span>
            </div>
            <div class="flex items-center gap-1 tabular-nums">
              <span><%= human_size(repository.total_size) %></span>
            </div>
          </div>
        </div>

        <div class="ml-4 flex-shrink-0">
          <svg class="w-5 h-5 text-slate-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
          </svg>
        </div>
      </div>

      <div class="mt-4 pt-4 border-t border-slate-100 dark:border-slate-700 flex items-center justify-between">
        <%= render(BadgeComponent.new(variant: :info)) { "Docker Image" } %>
        <% if repository.maintainer.present? %>
          <span class="text-sm text-slate-400 dark:text-slate-500"><%= repository.maintainer %></span>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
