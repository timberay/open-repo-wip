<%# Page header %>
<div class="mb-6">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100 mb-1">Setup Guide</h1>
  <p class="text-sm text-slate-600 dark:text-slate-400">Configure Docker and Kubernetes clients to use this registry.</p>
</div>

<%# Docker Daemon Configuration %>
<%= render CardComponent.new(padding: :none, class: "mb-6") do %>
  <div class="p-6">
    <h2 class="text-xl font-semibold text-slate-900 dark:text-slate-100 mb-4">Docker Daemon Configuration</h2>
    <p class="text-base text-slate-700 dark:text-slate-300 mb-3">Add this registry as an insecure registry in <code class="bg-slate-100 dark:bg-slate-900 px-1.5 py-0.5 rounded text-sm font-mono">/etc/docker/daemon.json</code>:</p>
    <pre class="bg-slate-100 dark:bg-slate-900 rounded-md p-4 text-sm font-mono text-slate-800 dark:text-blue-300 overflow-x-auto">{
  "insecure-registries": ["<%= @registry_host %>"]
}</pre>
    <p class="text-sm text-slate-500 dark:text-slate-400 mt-3">Restart Docker after making changes: <code class="bg-slate-100 dark:bg-slate-900 px-1.5 py-0.5 rounded text-sm font-mono">sudo systemctl restart docker</code></p>
  </div>
<% end %>

<%# HTTP vs HTTPS (B-39) %>
<%= render CardComponent.new(padding: :none, class: "mb-6") do %>
  <div class="p-6">
    <h2 class="text-xl font-semibold text-slate-900 dark:text-slate-100 mb-4">HTTP vs HTTPS</h2>
    <p class="text-base text-slate-700 dark:text-slate-300 mb-3">
      Docker daemon refuses plain HTTP registries by default. You have two options:
    </p>
    <ul class="list-disc list-inside text-sm text-slate-700 dark:text-slate-300 space-y-2 mb-3">
      <li>
        <strong>Development / intranet:</strong> add the host to
        <code class="bg-slate-100 dark:bg-slate-900 px-1.5 py-0.5 rounded text-sm font-mono">insecure-registries</code>
        in <code class="bg-slate-100 dark:bg-slate-900 px-1.5 py-0.5 rounded text-sm font-mono">/etc/docker/daemon.json</code> (see Daemon Configuration above).
      </li>
      <li>
        <strong>Production:</strong> terminate TLS at a reverse proxy (Nginx example below) and serve the registry over <code class="bg-slate-100 dark:bg-slate-900 px-1.5 py-0.5 rounded text-sm font-mono">https://</code>. No client config needed.
      </li>
    </ul>
    <p class="text-sm text-slate-500 dark:text-slate-400">
      Credentials sent to a plain-HTTP registry are visible on the wire. Use HTTPS whenever the registry is reachable beyond a single trusted host.
    </p>
  </div>
<% end %>

<%# Personal Access Tokens (B-37) %>
<%= render CardComponent.new(padding: :none, class: "mb-6") do %>
  <div class="p-6">
    <h2 class="text-xl font-semibold text-slate-900 dark:text-slate-100 mb-4">Personal Access Tokens</h2>
    <p class="text-base text-slate-700 dark:text-slate-300 mb-3">
      The Docker CLI authenticates with this registry using a Personal Access Token (PAT).
      Generate one from <%= link_to "Settings → Tokens", settings_tokens_path, class: "text-blue-600 dark:text-blue-400 hover:underline" %>.
    </p>
    <ol class="list-decimal list-inside text-sm text-slate-700 dark:text-slate-300 space-y-1 mb-3">
      <li>Sign in with your work Google account.</li>
      <li>Open <code class="bg-slate-100 dark:bg-slate-900 px-1.5 py-0.5 rounded text-sm font-mono">/settings/tokens</code> and click <strong>New token</strong>.</li>
      <li>Copy the token shown once — it will not be displayed again.</li>
      <li>Use the token as the password in <code class="bg-slate-100 dark:bg-slate-900 px-1.5 py-0.5 rounded text-sm font-mono">docker login</code>.</li>
    </ol>
    <p class="text-sm text-slate-500 dark:text-slate-400">
      Tokens begin with <code class="bg-slate-100 dark:bg-slate-900 px-1.5 py-0.5 rounded text-sm font-mono">oprk_</code> and the next 7 chars form the visible <em>prefix</em> shown in the token list, so you can identify which one is on which machine.
    </p>
  </div>
<% end %>

<%# Sign-in → Token → docker login walkthrough (B-46) %>
<%= render CardComponent.new(padding: :none, class: "mb-6") do %>
  <div class="p-6">
    <h2 class="text-xl font-semibold text-slate-900 dark:text-slate-100 mb-4">Sign in, generate token, docker login</h2>
    <ol class="list-decimal list-inside text-base text-slate-700 dark:text-slate-300 space-y-2 mb-3">
      <li>Visit <%= link_to "/sign_in", sign_in_path, class: "text-blue-600 dark:text-blue-400 hover:underline" %> and complete Google sign-in.</li>
      <li>Open <%= link_to "Settings → Tokens", settings_tokens_path, class: "text-blue-600 dark:text-blue-400 hover:underline" %>, name a token (e.g. <code class="bg-slate-100 dark:bg-slate-900 px-1.5 py-0.5 rounded text-sm font-mono">laptop-cli</code>), choose an expiry, and create.</li>
      <li>Copy the token immediately — it appears once.</li>
      <li>Run <code class="bg-slate-100 dark:bg-slate-900 px-1.5 py-0.5 rounded text-sm font-mono">docker login</code>:</li>
    </ol>
    <pre class="bg-slate-100 dark:bg-slate-900 rounded-md p-4 text-sm font-mono text-slate-800 dark:text-blue-300 overflow-x-auto">docker login <%= @registry_host %> -u your.email@company.com -p oprk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx</pre>
    <p class="text-sm text-slate-500 dark:text-slate-400 mt-3">
      Successful login stores credentials in <code class="bg-slate-100 dark:bg-slate-900 px-1.5 py-0.5 rounded text-sm font-mono">~/.docker/config.json</code>. After that, <code class="bg-slate-100 dark:bg-slate-900 px-1.5 py-0.5 rounded text-sm font-mono">docker push</code> and <code class="bg-slate-100 dark:bg-slate-900 px-1.5 py-0.5 rounded text-sm font-mono">docker pull</code> use the saved token automatically.
    </p>
  </div>
<% end %>

<%# Push & Pull %>
<%= render CardComponent.new(padding: :none, class: "mb-6") do %>
  <div class="p-6">
    <h2 class="text-xl font-semibold text-slate-900 dark:text-slate-100 mb-4">Push & Pull Images</h2>
    <p class="text-sm text-slate-600 dark:text-slate-400 mb-4">
      Authenticate with a token from <%= link_to "Settings → Tokens", settings_tokens_path, class: "text-blue-600 dark:text-blue-400 hover:underline" %>.
      Tokens begin with <code class="bg-slate-100 dark:bg-slate-900 px-1.5 py-0.5 rounded text-sm font-mono">oprk_</code> — the prefix that identifies an open-repo personal access token.
    </p>
    <div class="space-y-4">
      <div>
        <h3 class="text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Tag an image for this registry</h3>
        <pre class="bg-slate-100 dark:bg-slate-900 rounded-md p-4 text-sm font-mono text-slate-800 dark:text-blue-300 overflow-x-auto">docker tag myapp:latest <%= @registry_host %>/myapp:latest</pre>
      </div>
      <div>
        <h3 class="text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Push</h3>
        <pre class="bg-slate-100 dark:bg-slate-900 rounded-md p-4 text-sm font-mono text-slate-800 dark:text-blue-300 overflow-x-auto">docker push <%= @registry_host %>/myapp:latest</pre>
      </div>
      <div>
        <h3 class="text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Pull</h3>
        <pre class="bg-slate-100 dark:bg-slate-900 rounded-md p-4 text-sm font-mono text-slate-800 dark:text-blue-300 overflow-x-auto">docker pull <%= @registry_host %>/myapp:latest</pre>
      </div>
    </div>
  </div>
<% end %>

<%# Kubernetes Configuration %>
<%= render CardComponent.new(padding: :none, class: "mb-6") do %>
  <div class="p-6">
    <h2 class="text-xl font-semibold text-slate-900 dark:text-slate-100 mb-4">Kubernetes / containerd Configuration</h2>
    <p class="text-base text-slate-700 dark:text-slate-300 mb-3">Add a mirror in <code class="bg-slate-100 dark:bg-slate-900 px-1.5 py-0.5 rounded text-sm font-mono">/etc/containerd/config.toml</code>:</p>
    <pre class="bg-slate-100 dark:bg-slate-900 rounded-md p-4 text-sm font-mono text-slate-800 dark:text-blue-300 overflow-x-auto">[plugins."io.containerd.grpc.v1.cri".registry.mirrors."<%= @registry_host %>"]
  endpoint = ["http://<%= @registry_host %>"]

[plugins."io.containerd.grpc.v1.cri".registry.configs."<%= @registry_host %>".tls]
  insecure_skip_verify = true</pre>
    <p class="text-sm text-slate-500 dark:text-slate-400 mt-3">Restart containerd: <code class="bg-slate-100 dark:bg-slate-900 px-1.5 py-0.5 rounded text-sm font-mono">sudo systemctl restart containerd</code></p>
  </div>
<% end %>

<%# Nginx Reverse Proxy %>
<%= render CardComponent.new(padding: :none, class: "mb-6") do %>
  <div class="p-6">
    <h2 class="text-xl font-semibold text-slate-900 dark:text-slate-100 mb-4">Nginx Reverse Proxy (TLS)</h2>
    <pre class="bg-slate-100 dark:bg-slate-900 rounded-md p-4 text-sm font-mono text-slate-800 dark:text-blue-300 overflow-x-auto">server {
    listen 443 ssl;
    server_name registry.example.com;

    ssl_certificate     /etc/ssl/certs/registry.crt;
    ssl_certificate_key /etc/ssl/private/registry.key;

    client_max_body_size 0;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}</pre>
  </div>
<% end %>

<%# Supported Image Formats %>
<div class="rounded-lg bg-amber-100 dark:bg-amber-900/20 border border-amber-400 dark:border-amber-700 p-6">
  <h2 class="text-xl font-semibold text-amber-800 dark:text-amber-200 mb-2">Supported Image Formats</h2>
  <p class="text-base text-amber-700 dark:text-amber-300 mb-3">
    This registry accepts <strong>single-platform Docker V2 Schema 2</strong> images only.
    If you attempt to push a multi-architecture manifest list, the registry will reject it with a <code class="bg-amber-200 dark:bg-amber-900/30 px-1.5 py-0.5 rounded text-sm font-mono">415 Unsupported Media Type</code> error.
  </p>
  <p class="text-sm font-medium text-amber-700 dark:text-amber-300 mb-2">How to resolve:</p>
  <p class="text-sm text-amber-600 dark:text-amber-400 mb-1">Ensure the image was built for a single platform before pushing. For example:</p>
  <pre class="bg-amber-200 dark:bg-amber-900/30 rounded-md p-4 text-sm font-mono text-amber-800 dark:text-amber-300 mt-2 overflow-x-auto"><%# Build with explicit single platform %>
docker build --platform linux/amd64 -t <%= @registry_host %>/myapp:v1.0.0 .
docker push <%= @registry_host %>/myapp:v1.0.0

<%# Or extract a single platform from an existing multi-arch image %>
docker pull --platform linux/amd64 nginx:latest
docker tag nginx:latest <%= @registry_host %>/nginx:latest
docker push <%= @registry_host %>/nginx:latest</pre>
</div>
