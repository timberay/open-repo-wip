#!/usr/bin/env bash
# Clean up stale server PIDs

PID_FILE="tmp/pids/server.pid"

if [ -f "$PID_FILE" ]; then
  PID=$(cat "$PID_FILE")
  echo "Found PID file with PID: $PID"
  
  if ps -p "$PID" > /dev/null 2>&1; then
    echo "Server is running. Stopping it..."
    kill -TERM "$PID" 2>/dev/null
    sleep 2
    
    if ps -p "$PID" > /dev/null 2>&1; then
      echo "Force killing server..."
      kill -9 "$PID" 2>/dev/null
    fi
    echo "Server stopped."
  else
    echo "PID file exists but process is not running. Removing stale PID file."
  fi
  
  rm -f "$PID_FILE"
  echo "PID file removed."
else
  echo "No PID file found. Nothing to clean up."
fi

echo "✓ Cleanup complete. You can now run bin/dev"
