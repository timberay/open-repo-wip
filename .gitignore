# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# ============================================================
# Ruby / Rails
# ============================================================
/.bundle
/vendor/bundle
*.rbc
.rspec_status
capybara-*.html
*.pid

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files, registry blobs, SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key
/config/credentials/*.key

# Compiled assets
/app/assets/builds/*
!/app/assets/builds/.keep

# ============================================================
# SQLite databases
# ============================================================
/db/*.sqlite3
/db/*.sqlite3-*
/storage/*.sqlite3
/storage/*.sqlite3-*

# ============================================================
# Environment files
# ============================================================
/.env*
!/.env.example

# ============================================================
# Node.js
# ============================================================
/node_modules/
package-lock.json
yarn.lock
yarn-error.log
npm-debug.log*
.npm

# ============================================================
# Playwright / E2E testing
# ============================================================
/playwright-report/
/test-results/
/playwright/.cache/
.playwright-mcp/
screenshot-*.png
screenshot-*.jpeg
/docs/screenshots/
/docs/e2e-test-report.md

# ============================================================
# IDE / Editor files
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================
# CI / Build artifacts
# ============================================================
/coverage/
.byebug_history

# ============================================================
# Git worktrees
# ============================================================
/.worktrees/
/tmp/ui-baseline/
.gstack/
